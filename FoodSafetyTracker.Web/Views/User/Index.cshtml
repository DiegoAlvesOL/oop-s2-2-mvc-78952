@model List<(Microsoft.AspNetCore.Identity.IdentityUser User, string Role)>

@{
    ViewData["Title"] = "Users";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Users</h2>
    <a asp-action="Create" class="btn btn-primary">+ New User</a>
</div>

<table class="table table-striped table-hover">
    <thead class="table-dark">
    <tr>
        <th>Username</th>
        <th>Email</th>
        <th>Role</th>
        <th>Actions</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var (user, role) in Model)
    {
        <tr>
            <td>@user.UserName</td>
            <td>@user.Email</td>
            <td>
                @{
                    var badgeClass = role switch
                    {
                        "Admin" => "badge bg-danger",
                        "Inspector" => "badge bg-primary",
                        "Viewer" => "badge bg-secondary",
                        _ => "badge bg-light text-dark"
                    };
                }
                <span class="@badgeClass">@role</span>
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-sm btn-warning">Edit</a>
                <a asp-action="Delete" asp-route-id="@user.Id" class="btn btn-sm btn-danger">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>
