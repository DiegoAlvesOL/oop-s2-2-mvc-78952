@model FoodSafetyTracker.Application.ViewModels.Inspection.InspectionFormViewModel

@{
    ViewData["Title"] = "Create Inspection";
}

<h2>Create Inspection</h2>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label asp-for="PremisesId" class="form-label"></label>
                <select asp-for="PremisesId" asp-items="Model.PremisesList" class="form-select">
                    <option value="">-- Select Premises --</option>
                </select>
                <span asp-validation-for="PremisesId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="InspectionDate" class="form-label"></label>
                <input asp-for="InspectionDate" type="date" class="form-control" />
                <span asp-validation-for="InspectionDate" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Score" class="form-label"></label>
                <input asp-for="Score" type="number" min="0" max="100" class="form-control" />
                <span asp-validation-for="Score" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Outcome" class="form-label"></label>
                <select asp-for="Outcome" asp-items="Html.GetEnumSelectList<FoodSafetyTracker.Domain.Enums.InspectionOutcome>()" class="form-select">
                    <option value="">-- Select Outcome --</option>
                </select>
                <span asp-validation-for="Outcome" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Notes" class="form-label"></label>
                <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Notes" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">Create</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}